{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Total Threatened Species by Australian State & Territory",
    "subtitle": "Combined counts of both plantae and animalia kingdoms",
    "anchor": "start",
    "fontSize": 16
  },
  "width": 600,
  "height": 400,
  "data": {
    "url": "data/threatened_species_state_list"
  },
  "transform": [
    {
      "fold": ["ACT", "NSW", "NT", "QLD", "SA", "TAS", "VIC", "WA"],
      "as": ["State", "Presence"]
    },
    {
      "filter": "datum.Presence === 'Yes'"
    }
  ],
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 4,
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "State",
      "type": "nominal",
      "title": "State / Territory",
      "sort": {
        "op": "count",
        "field": "Presence",
        "order": "descending"
      },
      "axis": {
        "labelAngle": 0
      }
    },
    "y": {
      "aggregate": "count",
      "type": "quantitative",
      "title": "Number of Threatened Species"
    },
    "color": {
      "field": "State",
      "type": "nominal",
      "scale": {
        "scheme": "viridis"
      },
      "legend": null
    }
  }
}