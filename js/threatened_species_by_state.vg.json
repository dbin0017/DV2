{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 400,
  "height": 300,
  "data": {
    "url": "https://raw.githubusercontent.com/dbin0017/DV2/main/data/threatened_species_state_list.csv"
  },
  "transform": [
    {
      "fold": ["ACT", "NSW", "NT", "QLD", "SA", "TAS", "VIC", "WA"],
      "as": ["State", "Presence"]
    },
    {
      "filter": "datum.Presence === 'Yes'"
    }
  ],
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 4,
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "State",
      "type": "nominal",
      "title": "State / Territory",
      "sort": {
        "op": "count",
        "field": "Presence",
        "order": "descending"
      },
      "axis": {
        "labelAngle": 0
      }
    },
    "y": {
      "aggregate": "count",
      "type": "quantitative",
      "title": "Number of Threatened Species"
    },
    "color": {
      "field": "State",
      "type": "nominal",
      "scale": {
        "scheme": "viridis"
      },
      "legend": null
    }
  }
}