{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width":340,
  "height": 300,
  "autosize": {
      "type": "fit",
      "contains": "padding"
  },
  "data": {"url": "https://raw.githubusercontent.com/dbin0017/DV2/main/data/cumulative_extinct_mammal.csv"},
  "mark": {"type": "line", "strokeWidth": 3},
  "encoding": {
    "x": {"field": "Decade", "type": "temporal"},
    "y": {"field": "Cumulative number of extinct mammal species", "type": "quantitative"},
    "color": {"value": "#bc6c25"},
    "tooltip": [
      {"field": "Decade", "type": "temporal"},
      {"field": "Cumulative number of extinct mammal species", "type": "quantitative"}
    ]
  }
}