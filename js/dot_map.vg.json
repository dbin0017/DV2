{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 400,
    "height": 300,
    "projection": {"type":"mercator"},
    "layer": [
        {
            "data": {
                "url": "https://raw.githubusercontent.com/tonywr71/GeoJson-Data/master/australian-states.json",
                "format": {"type": "json", "property": "features"}
            },
            "transform": [
                {
                    "lookup": "properties.STATE_NAME",
                    "from": {
                        "data":{
                            "values": [
                                {"State": "Australian Capital Territory", "NumberOfReserve": 47, "Area": 2358},
                                {"State": "New South Wales", "NumberOfReserve": 1057, "Area": 801150},
                                {"State": "Northern Territory", "NumberOfReserve": 115, "Area": 1347791},
                                {"State": "Queensland", "NumberOfReserve": 1190, "Area": 1729742},
                                {"State": "South Australia", "NumberOfReserve": 1990, "Area": 984321},
                                {"State": "Tasmania", "NumberOfReserve": 1612, "Area": 68401},
                                {"State": "Victoria", "NumberOfReserve": 3255, "Area": 227444},
                                {"State": "Western Australia", "NumberOfReserve": 1894, "Area": 2527013}
                            ]
                        },
                        "key": "State",
                        "fields": ["NumberOfReserve", "Area"]
                    }
                },
                {"calculate": "toNumber(datum.NumberOfReserve)/toNumber(datum.Area) * 100000",
                "as": "Reserves per 100k km2 area"}
            ],
            "mark": {"type": "geoshape"},
            "encoding": {
                "color": {
                    "field": "Reserves per 100k km2 area",
                    "type": "quantitative",
                    "scale": {
                        "type": "threshold",
                        "domain": [20, 100, 250, 1500],
                        "range": ["#ffe169", "#edc531", "#dbb42c", "#b69121", "#926c15"]
                    }
                },
                "tooltip": [
                    {"field": "properties.STATE_NAME", "type":"nominal", "title": "State"},
                    {"field": "NumberOfReserve", "type":"quantitative"},
                    {"field": "Reserves per 100k km2 area", "type":"quantitative", "format": ".2f"}
                ]
            }
        },

        {
            "data": {
                "url": "https://raw.githubusercontent.com/dbin0017/DV2/main/data/reserve_locations.csv",
                "format": {
                    "type": "csv",
                    "parse": {
                        "X_COORD": "number",
                        "Y_COORD": "number"
                    }
                }
            },
            "transform": [
                {
                    "filter": "datum.STATE != 'EXT'"
                }
            ],
            "mark": {
                "type": "circle",
                "size": 2,
                "color": "indianred",
                "opacity": 0.5
            },
            "encoding": {
                "longitude": {"field": "X_COORD", "type": "quantitative"},
                "latitude": {"field": "Y_COORD", "type": "quantitative"},
                "tooltip": [
                    {"field": "NAME", "type":"nominal"},
                    {"field": "TYPE", "type":"nominal"}
                ]
            }
        }
    ]
}