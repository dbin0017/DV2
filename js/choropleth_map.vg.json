{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 600,
    "height": 600,
    "projection": {"type":"mercator"},
    "data": {
        "url": "https://raw.githubusercontent.com/tonywr71/GeoJson-Data/master/australian-states.json",
        "format": {"type": "json", "property": "features"}
    },
    "transform": [
        {
            "lookup": "properties.STATE_NAME",
            "from": {
                "data": {
                    "values": [
                        {"State": "Australian Capital Territory", "ThreatenedSpecies": 71, "Area": 2358},
                        {"State": "New South Wales", "ThreatenedSpecies": 760, "Area": 801150},
                        {"State": "Northern Territory", "ThreatenedSpecies": 155, "Area": 1347791},
                        {"State": "Queensland", "ThreatenedSpecies": 612, "Area": 1729742},
                        {"State": "South Australia", "ThreatenedSpecies": 319, "Area": 984321},
                        {"State": "Tasmania", "ThreatenedSpecies": 230, "Area": 68401},
                        {"State": "Victoria", "ThreatenedSpecies": 357, "Area": 227444},
                        {"State": "Western Australia", "ThreatenedSpecies": 614, "Area": 2527013}
                    ]
                },
                "key": "State",
                "fields": ["ThreatenedSpecies", "Area"]
            }
        },
        {"calculate": "toNumber(datum.ThreatenedSpecies)/toNumber(datum.Area) * 100000", 
        "as": "Species per 100k km2 area"}
    ],
    "mark": {"type": "geoshape"},
    "encoding": {
        "color": {
            "field": "Species per 100k km2 area",
            "type": "quantitative",
            "scale": {
                "type": "threshold",
                "domain": [15, 30, 60, 120, 250],
                "range": ["#ffe169", "#edc531", "#dbb42c", "#b69121", "#926c15", "#76520e"]
            }
        },
        "tooltip": [
            {"field": "properties.STATE_NAME", "type": "nominal", "title": "State"},
            {"field": "ThreatenedSpecies", "type": "quantitative"},
            {"field": "Species per 100k km2 area", "type": "quantitative", "format": ".2f"}
        ]
    }
}