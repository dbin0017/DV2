{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 400,
  "height": 300,
  "title": {
    "text": "Note:",
    "fontSize": 11,
    "fontStyle": "bold",
    "anchor": "start",
    "subtitle": [
      "Certain groups only contain records",
      "for specific indicator subsets."
     ],
    "subtitleColor": "dimgray",
    "subtitleFontSize": 11,
    "orient": "bottom"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/dbin0017/DV2/main/data/expected_survival.csv"
  },
  "params": [
    {
      "name": "GroupSelect",
      "value": "Tetrapods",
      "bind": {
        "input": "select",
        "options": [
          "Tetrapods",
          "Terrestrial",
          "Transitional (Terrestrial - Freshwater)",
          "Transitional (Terrestrial - Marine)",
          "Other",
          "Vascular plants",
          "Gymnosperms",
          "Proteaceae"
        ],
        "name": "Select Group: "
      }
    },
    {
      "name": "IndicatorSelect",
      "value": "Expected survival of listed threatened species",
      "bind": {
        "input": "select",
        "options": [
          "Expected survival of listed threatened species",
          "Expected survival of listed threatened ecological communities",
          "Phylogenetic diversity"
        ],
        "name": "Indicator"
      }
    }
  ],
  "transform": [
    {
      "filter": "datum.Group === GroupSelect && datum.Indicator === IndicatorSelect && datum.Quantity === 'Percent'"
    }
  ],
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "Year",
      "type": "ordinal",
      "axis": {"labelAngle": 0}
    },
    "y": {
      "field": "Indicator value",
      "type": "quantitative",
      "title": "Percentage (%)",
      "stack": "zero"
    },
    "color": {
      "field": "Component",
      "type": "nominal",
      "scale": {
        "domain": ["exp_survival", "potential_loss", "already_lost"],
        "range": ["#e09f3e", "#9e2a2b", "#540b0e"]
      },
      "legend": {
        "title": "Survival Category",
        "orient": "right",
        "labelExpr": "datum.value == 'exp_survival' ? 'Expected Survival' : datum.value == 'potential_loss' ? 'Potential Loss' : 'Already Lost'"
      }
    },
    "tooltip": [
      {"field": "Year", "type": "ordinal"},
      {"field": "Component", "type": "nominal", "title":"Category"},
      {"field": "Indicator value", "type": "quantitative", "title":"Percentage", "format": ".2f"}
    ]
  }
}