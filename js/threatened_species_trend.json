{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 550,
  "height": 300,
  "title": "Threatened Species Trend in Australia (2007 - 2019)",
  "data": {
    "url": "https://raw.githubusercontent.com/dbin0017/2179/main/Data%20Visualisation%202/threatened_species_trends_long.csv",
    "format": {"type": "csv"}
  },
  "transform": [
    {"filter": "datum.Status === 'threatened'"}
  ],
  "mark": {"type": "line", "point": true},
  "encoding": {
    "x": {"field": "Year", "type": "ordinal", "title": "Year"},
    "y": {"field": "Count", "type": "quantitative", "title": "Number of Listed Species"},
    "color": {"field": "Group", "type": "nominal", "title": "Animal Group"},
    "tooltip": [
      {"field": "Group", "type": "nominal", "title": "Group"},
      {"field": "Year", "type": "ordinal", "title": "Year"},
      {"field": "Count", "type": "quantitative", "title": "Threatened Count"}
    ]
  }
}